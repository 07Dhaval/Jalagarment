{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "server.js"
        }
    ],
    "env": {
        "MONGODB_URI": "@mongodb_uri",
        "JWT_SECRET": "@jwt_secret",
        "JWT_EXPIRES_IN": "1d",
        "JWT_ISS": "jalagarment",
        "JWT_AUD": "jalagarment",
        "JWT_ALG": "HS256",
        "JWT_TYP": "JWT",
        "CLOUDINARY_NAME": "@cloudinary_name",
        "CLOUDINARY_API_KEY": "@cloudinary_api_key",
        "CLOUDINARY_API_SECRET": "@cloudinary_api_secret"
    }
}